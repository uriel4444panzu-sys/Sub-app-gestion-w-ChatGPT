rules_version = '2';

// Règles de sécurité Firestore de SubPilot.
//
// À publier dans la console Firebase :
//   Firestore Database > Règles > coller ce contenu > Publier.
//
// L'application enregistre, pour chaque utilisateur :
//   - users/{userId}/data/app          (abonnements, budget, catégories)
//   - users/{userId}/profile/details   (nom, prénom, photo, etc.)
//
// La règle ci-dessous couvre TOUTE l'arborescence de l'utilisateur
// (data ET profile) grâce à {document=**}, et garantit que chacun
// n'accède qu'à ses propres données.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
